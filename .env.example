NEXT_PUBLIC_API_URL=http://localhost:8081
# Optional server-side target for a same-origin /api proxy (recommended on Vercel).
# When set, leave NEXT_PUBLIC_API_URL empty in the deployed frontend.
API_PROXY_TARGET=
# Server-only secret injected into proxied /api requests; use the same value as
# backend ReverseProxy__RequiredHeaderSecret. Never prefix this with NEXT_PUBLIC_.
API_PROXY_SECRET=
# Vercel does not proxy the long-lived SignalR connection. In production point
# this public URL at the Azure Container App origin (authentication still uses JWT).
NEXT_PUBLIC_REALTIME_URL=

# Polish/EU legal identity. Keep status=draft until every value has been
# confirmed and the documents have passed Polish legal review.
LEGAL_DOCUMENTS_STATUS=draft
LEGAL_OPERATOR_NAME=
LEGAL_OPERATOR_ADDRESS=
LEGAL_OPERATOR_REGISTER=
LEGAL_OPERATOR_NIP=
LEGAL_CONTACT_EMAIL=support@worktogether.app
